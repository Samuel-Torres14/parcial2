/**
 * Universidad - Facultad de Ingenier=C3=ADa
 * Asignatura: Introducci=C3=B3n a la Computaci=C3=B3n Gr=C3=A1fica
 * Tarea: Rasterizaci=C3=B3n manual (Bresenham + Punto Medio)
 */

//  funcion para PIXEL=20
function drawPixel(ctx, x, y, color =3D "#000") {
    ctx.fillStyle =3D color;
    ctx.fillRect(Math.floor(x), Math.floor(y), 1, 1);
}

// la funcion Bresenham
function bresenhamLine(ctx, x0, y0, x1, y1, color =3D "#000") {

    x0 =3D Math.floor(x0);
    y0 =3D Math.floor(y0);
    x1 =3D Math.floor(x1);
    y1 =3D Math.floor(y1);

    let dx =3D Math.abs(x1 - x0);
    let dy =3D Math.abs(y1 - y0);

    let sx =3D (x0 &lt; x1) ? 1 : -1;
    let sy =3D (y0 &lt; y1) ? 1 : -1;

    let err =3D dx - dy;

    while (true) {
        drawPixel(ctx, x0, y0, color);

        if (x0 =3D=3D=3D x1 &amp;&amp; y0 =3D=3D=3D y1) break;

        let e2 =3D 2 * err;

        /**L=C3=B3gica del error:
         * e2 eval=C3=BAa si debemos movernos en X, Y o ambos.
         * Permite manejar todos los octantes (m &gt; 1, m &lt; 0, etc).*/

        if (e2 &gt; -dy) {
            err -=3D dy;
            x0 +=3D sx;
        }

        if (e2 &lt; dx) {
            err +=3D dx;
            y0 +=3D sy;
        }
    }
}

// funcion para circunferencia
function midpointCircle(ctx, xc, yc, r, color =3D "#000") {

    let x =3D 0;
    let y =3D r;

    let p =3D 1 - r;

    while (x &lt;=3D y) {

        // Simetr=C3=ADa de 8 octantes
        drawPixel(ctx, xc + x, yc + y, color);
        drawPixel(ctx, xc - x, yc + y, color);
        drawPixel(ctx, xc + x, yc - y, color);
        drawPixel(ctx, xc - x, yc - y, color);
        drawPixel(ctx, xc + y, yc + x, color);
        drawPixel(ctx, xc - y, yc + x, color);
        drawPixel(ctx, xc + y, yc - x, color);
        drawPixel(ctx, xc - y, yc - x, color);

        x++;

         /**Par=C3=A1metro de decisi=C3=B3n:
         * p &lt; 0 : el punto est=C3=A1 dentro y solo avanzamos en x
         * p &gt;=3D 0 : el punto est=C3=A1 fuera y decrementamos  y */

        if (p &lt; 0) {
            p =3D p + 2 * x + 1;
        } else {
            y--;
            p =3D p + 2 * (x - y) + 1;
        }
    }
}
// funcion para poligono (segun el ejemplo)
function getPolygonVertices(cx, cy, sides, radius) {

    let vertices =3D [];

    for (let i =3D 0; i &lt; sides; i++) {

        let angle =3D (2 * Math.PI * i) / sides;

        let x =3D cx + radius * Math.cos(angle);
        let y =3D cy + radius * Math.sin(angle);

        vertices.push({ x, y });
    }

    return vertices;
}
// parte del main para inicializar todo en conjunto=20
window.onload =3D function () {

    // obtiene el canvas y su contexto 2D para dibujar
    const canvas =3D document.getElementById("canvas");
    const ctx =3D canvas.getContext("2d");

    // calcula el centro del canvas (punto de referencia geometrico)
    const centerX =3D canvas.width / 2;
    const centerY =3D canvas.height / 2;

    // genera un numero aleatorio de lados entre 5 y 10
    const sides =3D Math.floor(Math.random() * 6) + 5;

    // define el radio del poligono
    const R =3D 150;

    // calcula los vertices del poligono usando trigonometria
    const vertices =3D getPolygonVertices(centerX, centerY, sides, R);

    /**dibujo del poligono:
     * Se conectan los vertices consecutivos mediante el algoritmo de Brese=
nham.
     * El uso de (i + 1) % n permite cerrar la figura uniendo el =C3=BAltim=
o v=C3=A9rtice con el primero.
     */
    for (let i =3D 0; i &lt; vertices.length; i++) {
        let p1 =3D vertices[i];
        let p2 =3D vertices[(i + 1) % vertices.length];

        bresenhamLine(ctx, p1.x, p1.y, p2.x, p2.y);
    }

    /**Dibujo de circunferencias en cada vertice:
     * Para cada punto del poligono se traza una circunferencia
     * usando el algoritmo de punto medio, con radio R/4.
     */
    vertices.forEach(v =3D&gt; {
        midpointCircle(ctx, v.x, v.y, R / 4);
    });

};

